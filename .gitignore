# -----------------------------
# ADAPTIVE-PARTICLEPHYSICS-TRIGGER .gitignore
# -----------------------------

# === Datasets ===
# Ignore all local data files (Zenodo-hosted)
Data/*.h5
Data/**/*.h5
Data/python/*
Data/*.pdf
Data/*.png
Data/python/
# === Outputs / Plots ===
runs/
results/
figs/
*.pdf
*.png
outputs/

# === Experiment tracking (wandb run logs/artifacts) ===
wandb/

# === Anomaly-detection benchmarks (UNSW-NB15, NAB, HAI) ===
# Ignore the datasets (~2 GB) and trained checkpoints; ship only the
# train/preprocess/rollout scripts so users regenerate them from the public
# UNSW-NB15 / NAB / HAI sources.
anomaly_detection/data/
anomaly_detection/models*/
*.pkl

# === Reference-only run scripts (kept locally, not in the open-source release) ===
# The 3 canonical entry points run_setting{1,2,3}_*.sh are tracked; everything
# below is the prior/ancillary runners kept locally for reference.
run_exp*.sh
run_multiseed_*.sh
run_pareto_holdout_*.sh
run_grpo_g_sweep_seeds.sh
sweep_dqn_hyperparams.sh
deploy_state_repr_ablation.sh
cutover_to_parallel.sh
watch_and_plot.sh

# === Temporary / Cache ===
__pycache__/
*.pyc
*.pyo
*.pyd
*.tmp
*.log
*.swp
.DS_Store
Thumbs.db

# === Python / Conda ===
.env
.venv
venv/
env/
*.egg-info/
*.egg
*.hdf5
*.h5
*.ckpt

# === Jupyter / Notebooks ===
.ipynb_checkpoints/
*.ipynb

# === IDE / Editor ===
.vscode/
.idea/
*.code-workspace

# === System / Mac ===
.DS_Store
.AppleDouble
.LSOverride

# Autoencoder models
*.keras

# Large numpy results
*.npz

Data_SingleTrigger.py
Run_SingleTrigger.py


paper/